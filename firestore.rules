rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ Helper: Is the user an Admin?
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 🛡️ Helper: Is the user a Volunteer?
    function isVolunteer() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'volunteer';
    }

    // 👤 User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin(); // Admin can change roles
    }

    // 📄 Intelligence Reports
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.privacy == 'Public' || 
        resource.data.privacy == null ||
        isAdmin() || 
        resource.data.creatorEmail == request.auth.token.email ||
        resource.data.assignedToEmail == request.auth.token.email
      );
      allow update: if request.auth != null && (
        isAdmin() || 
        resource.data.assignedToEmail == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    // ⚙️ System Settings
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write, update: if isAdmin();
    }

    // 📋 Tasks (For Volunteers)
    match /tasks/{taskId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        resource.data.assignedToEmail == request.auth.token.email
      );
      allow create, update: if isAdmin() || isVolunteer();
    }

    // 🔔 Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 📊 Analytics (Calculated data)
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
